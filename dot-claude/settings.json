  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Powershell"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Powershell|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\PC\\WorkBuddy\\Claw\\.claude\\hooks\\pre-tool-guard.ps1\" -ToolName ${TOOL_NAME} -Input ${INPUT}",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if grep -rE '(password|secret|token|api_key|access_key).*=.*[\"\\'']?[a-zA-Z0-9_-]{20,}' . --exclude-dir=.git --include='*.{ts,js,py,go,yaml,yml,json}' 2>/dev/null; then echo '[HOOK] WARNING: Possible credential detected in file to be written. ABORTING.'; exit 1; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\PC\\WorkBuddy\\Claw\\.claude\\hooks\\post-tool-log.ps1\" -ToolName ${TOOL_NAME} -Output ${OUTPUT}",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/HRSoftstore/Install/Clawlongxiabendibushuchushou/JHMoltbotIns/claws/nodejs/nodejs/bun run C:/Users/PC/.claude-memory-hub/dist/hooks/post-tool-use.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo [Claw] 项目灵魂已加载。五阶段体系就绪。",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/HRSoftstore/Install/Clawlongxiabendibushuchushou/JHMoltbotIns/claws/nodejs/nodejs/bun run C:/Users/PC/.claude-memory-hub/dist/hooks/user-prompt-submit.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/HRSoftstore/Install/Clawlongxiabendibushuchushou/JHMoltbotIns/claws/nodejs/nodejs/bun run C:/Users/PC/.claude-memory-hub/dist/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/HRSoftstore/Install/Clawlongxiabendibushuchushou/JHMoltbotIns/claws/nodejs/nodejs/bun run C:/Users/PC/.claude-memory-hub/dist/hooks/post-compact.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/HRSoftstore/Install/Clawlongxiabendibushuchushou/JHMoltbotIns/claws/nodejs/nodejs/bun run C:/Users/PC/.claude-memory-hub/dist/hooks/session-end.js"
          }
        ]
